{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev_vs_msvc",
      "displayName": "development (Visual Studio, MSVC)",
      "generator": "Visual Studio 18 2026",
      "toolchainFile": "${sourceDir}/build/generators/conan_toolchain.cmake",
      "cacheVariables": {
        "ENABLE_TESTS": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_CONFIGURATION_TYPES": "Debug"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "binaryDir": "${sourceDir}/build"
    }
  ],
  "buildPresets": [
    {
      "name": "dev_vs_msvc",
      "configurePreset": "dev_vs_msvc",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "dev_vs_msvc",
      "configurePreset": "dev_vs_msvc",
      "configuration": "Debug",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": true }
    }
  ]
}
