{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev",
      "hidden": true,
      "cacheVariables": {
        "ENABLE_TESTS": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "dev_ninja",
      "hidden": true,
      "inherits": "dev",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPERIMENTAL_CXX_IMPORT_STD": "f35a9ac6-8463-4d38-8eec-5d6008153e7d",
        "CMAKE_CXX_MODULE_STD": "ON"
      }
    },
    {
      "name": "dev_ninja_msvc",
      "displayName": "development (Ninja, MSVC) - run from a Developer PowerShell/Command Prompt",
      "inherits": "dev_ninja",
      "toolchainFile": "${sourceDir}/builds/dev_ninja_msvc/generators/conan_toolchain.cmake",
      "binaryDir": "${sourceDir}/builds/dev_ninja_msvc/build"
    },
    {
      "name": "dev_ninja_clang",
      "displayName": "development (Ninja, clang) - run from a Developer PowerShell/Command Prompt",
      "inherits": "dev_ninja",
      "toolchainFile": "${sourceDir}/builds/dev_ninja_clang/generators/conan_toolchain.cmake",
      "binaryDir": "${sourceDir}/builds/dev_ninja_clang/build",
      "cacheVariables": {
        "CMAKE_CXX_MODULE_STD": "OFF"
      },
      "environment": {
        "CXX": "clang++",
        "CC": "clang"
      }
    },
    {
      "name": "dev_ninja_clang_tidy",
      "displayName": "development (Ninja, clang, clang-tidy) - run from a Developer PowerShell/Command Prompt",
      "inherits": "dev_ninja_clang",
      "toolchainFile": "${sourceDir}/builds/dev_ninja_clang_tidy/generators/conan_toolchain.cmake",
      "binaryDir": "${sourceDir}/builds/dev_ninja_clang_tidy/build",
      "cacheVariables": {
        "ENABLE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": "dev_ninja_msvc_analysis",
      "displayName": "development (Ninja, MSVC, /analyze) - run from a Developer PowerShell/Command Prompt",
      "inherits": "dev_ninja_msvc",
      "toolchainFile": "${sourceDir}/builds/dev_ninja_msvc_analysis/generators/conan_toolchain.cmake",
      "binaryDir": "${sourceDir}/builds/dev_ninja_msvc_analysis/build",
      "cacheVariables": {
        "ENABLE_MSVC_ANALYSIS": "ON"
      }
    },
    {
      "name": "dev_ninja_clang_coverage",
      "displayName": "development (Ninja, clang, coverage) - run from a Developer PowerShell/Command Prompt",
      "inherits": "dev_ninja_clang",
      "toolchainFile": "${sourceDir}/builds/dev_ninja_clang_coverage/generators/conan_toolchain.cmake",
      "binaryDir": "${sourceDir}/builds/dev_ninja_clang_coverage/build",
      "cacheVariables": {
        "ENABLE_COVERAGE_REPORT": "ON"
      }
    },
    {
      "name": "dev_vs_msvc",
      "displayName": "development (Visual Studio, MSVC)",
      "inherits": "dev",
      "generator": "Visual Studio 18 2026",
      "toolchainFile": "${sourceDir}/builds/dev_vs_msvc/generators/conan_toolchain.cmake",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug",
        "CMAKE_EXPERIMENTAL_CXX_IMPORT_STD": "f35a9ac6-8463-4d38-8eec-5d6008153e7d",
        "CMAKE_CXX_MODULE_STD": "OFF"
      },
      "binaryDir": "${sourceDir}/builds/dev_vs_msvc/build"
    },
    {
      "name": "dev_vs_msvc_analysis",
      "displayName": "development (Visual Studio, MSVC, /analyze)",
      "inherits": "dev_vs_msvc",
      "toolchainFile": "${sourceDir}/builds/dev_vs_msvc_analysis/generators/conan_toolchain.cmake",
      "binaryDir": "${sourceDir}/builds/dev_vs_msvc_analysis/build",
      "cacheVariables": {
        "ENABLE_MSVC_ANALYSIS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev_ninja_msvc",
      "configurePreset": "dev_ninja_msvc"
    },
    {
      "name": "dev_ninja_clang",
      "configurePreset": "dev_ninja_clang"
    },
    {
      "name": "dev_ninja_clang_tidy",
      "configurePreset": "dev_ninja_clang_tidy"
    },
    {
      "name": "dev_ninja_msvc_analysis",
      "configurePreset": "dev_ninja_msvc_analysis"
    },
    {
      "name": "dev_ninja_clang_coverage",
      "configurePreset": "dev_ninja_clang_coverage"
    },
    {
      "name": "dev_vs_msvc",
      "configurePreset": "dev_vs_msvc",
      "configuration": "Debug"
    },
    {
      "name": "dev_vs_msvc_analysis",
      "configurePreset": "dev_vs_msvc_analysis",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "hidden": true,
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": true }
    },
    {
      "name": "dev_ninja_msvc",
      "inherits": "default",
      "configurePreset": "dev_ninja_msvc"
    },
    {
      "name": "dev_ninja_clang",
      "inherits": "default",
      "configurePreset": "dev_ninja_clang"
    },
    {
      "name": "dev_ninja_clang_tidy",
      "inherits": "default",
      "configurePreset": "dev_ninja_clang_tidy"
    },
    {
      "name": "dev_ninja_msvc_analysis",
      "inherits": "default",
      "configurePreset": "dev_ninja_msvc_analysis"
    },
    {
      "name": "dev_ninja_clang_coverage",
      "inherits": "default",
      "configurePreset": "dev_ninja_clang_coverage"
    },
    {
      "name": "dev_vs_msvc",
      "inherits": "default",
      "configurePreset": "dev_vs_msvc",
      "configuration": "Debug"
    },
    {
      "name": "dev_vs_msvc_analysis",
      "inherits": "default",
      "configurePreset": "dev_vs_msvc_analysis",
      "configuration": "Debug"
    }
  ]
}
